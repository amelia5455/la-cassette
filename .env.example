# ─────────────────────────────────────────────────────────────────────────────
# La Cassette — environment
#
# The app runs end-to-end in DEMO MODE with none of these set (mocked playlists
# and matches, identical to the prototype). Fill them in to switch each service
# to its real integration.
# ─────────────────────────────────────────────────────────────────────────────

# Public base URL of the deployment (used for OAuth redirects + share links).
# Locally: http://localhost:3000 . On Vercel it falls back to VERCEL_URL.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Spotify ──────────────────────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
# Add redirect URI: ${NEXT_PUBLIC_BASE_URL}/api/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Apple Music (MusicKit) ───────────────────────────────────────────────────
# From https://developer.apple.com  → Keys → MusicKit (.p8)
APPLE_TEAM_ID=
APPLE_KEY_ID=
# The .p8 private key contents. Either paste the PEM here (with literal \n or
# real newlines), or set APPLE_PRIVATE_KEY_PATH to a file on disk (local dev).
APPLE_PRIVATE_KEY=
APPLE_PRIVATE_KEY_PATH=
# Catalog storefront used for ISRC lookups (e.g. us, gb, de).
APPLE_STOREFRONT=us

# ── Tape storage (Upstash Redis via Vercel Marketplace) ──────────────────────
# Provision: Vercel → Storage → Upstash Redis. These vars are injected
# automatically. Without them the app uses an in-memory store (dev only).
KV_REST_API_URL=
KV_REST_API_TOKEN=
# (Upstash's own names also work if present)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Secret used to sign session cookies holding OAuth tokens.
SESSION_SECRET=change-me-to-a-long-random-string
